# Auto detect text files and normalize line endings to LF
* text=auto

# Source code files
*.cs text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf
*.json text eol=crlf
*.xml text eol=crlf
*.config text eol=crlf

# Binary files
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
